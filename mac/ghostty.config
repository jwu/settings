# ============================================================
# Ghostty Configuration
# Migrated from wezterm.lua + alacritty.toml
# ============================================================

# ------------------------------------------------------------
# Font
# ------------------------------------------------------------
font-family = FiraMono Nerd Font
font-family-bold = FiraMono Nerd Font
font-family-italic = FiraMono Nerd Font
font-family-bold-italic = FiraMono Nerd Font
font-size = 16
font-style = Medium
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic
font-thicken = true
font-thicken-strength = 0
# alpha-blending = linear-corrected

# Chinese fallback font
font-family = PingFang SC

# ------------------------------------------------------------
# Colors (One Half Dark / OneDark)
# ------------------------------------------------------------
term = xterm-256color
theme = One Half Dark

# background = 282c34
# foreground = dcdfe4

# # Normal colors
# palette = 0=282c34
# palette = 1=e06c75
# palette = 2=98c379
# palette = 3=e5c07b
# palette = 4=61afef
# palette = 5=c678dd
# palette = 6=56b6c2
# palette = 7=dcdfe4
#
# # Bright colors
# palette = 8=5c6370
# palette = 9=e06c75
# palette = 10=98c379
# palette = 11=e5c07b
# palette = 12=61afef
# palette = 13=c678dd
# palette = 14=56b6c2
# palette = 15=dcdfe4

# Cursor
cursor-color = dcdfe4
cursor-text = 282c34

# Selection
selection-background = 3b3f4c
selection-foreground = cell-foreground
# selection-foreground = dcdfe4

# ------------------------------------------------------------
# Cursor
# ------------------------------------------------------------
cursor-style = block
cursor-style-blink = true
shell-integration-features = no-cursor

# ------------------------------------------------------------
# Window
# ------------------------------------------------------------
background-opacity = 0.95
window-padding-x = 2
window-padding-y = 2
window-padding-balance = true

# macOS: use native decorations
macos-titlebar-style = tabs

# ------------------------------------------------------------
# Scrollback
# ------------------------------------------------------------
scrollback-limit = 10000

# ------------------------------------------------------------
# Mouse
# ------------------------------------------------------------
mouse-hide-while-typing = false

# ------------------------------------------------------------
# Selection
# ------------------------------------------------------------
copy-on-select = true

# ------------------------------------------------------------
# Bell
# ------------------------------------------------------------
bell-features = false

# ------------------------------------------------------------
# Tab Bar
# ------------------------------------------------------------
# Ghostty has native tabs on macOS, enabled by default.
# Active tab color (approximate wezterm purple theme)
# These require macos-titlebar-style = native to take effect
macos-titlebar-proxy-icon = hidden

# ------------------------------------------------------------
# Key Bindings
# ------------------------------------------------------------
# New window (CMD+N)
keybind = cmd+n=new_window

# Close pane/tab (CMD+W)
keybind = cmd+w=close_surface

# Split pane
keybind = cmd+shift+left=new_split:left
keybind = cmd+shift+right=new_split:right
keybind = cmd+shift+up=new_split:up
keybind = cmd+shift+down=new_split:down

# Navigate between panes
keybind = shift+left=goto_split:left
keybind = shift+right=goto_split:right
keybind = shift+up=goto_split:up
keybind = shift+down=goto_split:down

# ------------------------------------------------------------
# Misc
# ------------------------------------------------------------
# Auto reload config
# Auto reload config (Ghostty watches config automatically, no extra config needed)

# Confirm close
confirm-close-surface = false

# Bold text uses bright colors
bold-is-bright = true
